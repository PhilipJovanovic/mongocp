# MongoDB connection string (mongodb:// or mongodb+srv://)
MONGO_URI=mongodb://localhost:27017

# Database this instance operates on
MONGO_DB=mongocp

# Bearer token clients must send as "Authorization: Bearer <token>".
# Generate one with: openssl rand -hex 32
API_TOKEN=change-me

# Public base URL of this service, used in the OpenAPI spec
# (falls back to the request host if unset)
PUBLIC_URL=https://mongocp.example.com

# HTTP port (default 8080)
PORT=8080
